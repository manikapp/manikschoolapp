# Supabase — from your project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role / secret key — from the SAME Settings > API page, but a
# DIFFERENT key (labeled "service_role" or "secret", not "anon"/"publishable").
# Used ONLY server-side (app/api/auth/register-school) to create the first
# admin account before any RLS-authorized user exists yet.
# NEVER add the NEXT_PUBLIC_ prefix to this one — that would expose it to
# the browser and let anyone bypass every RLS policy in the database.
SUPABASE_SERVICE_ROLE_KEY=

# Used to sign/verify QR tokens (lib/qr.ts) — any long random string, keep it secret
QR_SIGNING_SECRET=
